<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>CertWatch</RootNamespace>
    <AssemblyName>certwatch</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
    <Version>0.0.0-dev</Version>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <Authors>Factus Consulting ApS</Authors>
    <Description>Agent-friendly CLI for monitoring SSL/TLS certificate expiry across many hosts.</Description>
    <RepositoryUrl>https://github.com/FactusConsulting/certwatch</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Spectre.Console" Version="0.57.2" />
    <PackageReference Include="Spectre.Console.Cli" Version="0.55.0" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="certwatch.Tests" />
  </ItemGroup>
</Project>
